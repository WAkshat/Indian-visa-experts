{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "india-visa-expert",
  "compatibility_date": "2024-12-30",
  // Static-assets-only deployment (no Worker script) — files in ./out are
  // served directly from Cloudflare's edge. No CPU limits, no cold starts.
  "assets": {
    "directory": "./out",
    "not_found_handling": "404-page"
  }
}
